{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "mypeople-memory-sandbox",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-17",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "mypeople-memory-sandbox-db",
			"migrations_dir": "migrations"
		}
	],
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "mypeople-memory-sandbox-vectors"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"kv_namespaces": [
		{
			"binding": "OAUTH_KV"
		}
	],
	"vars": {
		"VECTORIZE_GRACE_MS": "300000",
		"MYPEOPLE_PILOT_READ_ONLY": "true",
		"MYPEOPLE_ALLOWED_PROJECTS": "pilot-alpha,pilot-beta,pilot-gamma",
		"MYPEOPLE_ENABLE_VECTOR_RECALL": "false"
	},
	"secrets": {
		"required": ["AUTH_TOKEN"]
	}
}
